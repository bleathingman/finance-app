# ─── Firebase (front-end) ──────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Stripe (front-end) ───────────────────────────────────────────
VITE_STRIPE_PUBLIC_KEY=pk_live_xxx
VITE_STRIPE_PREMIUM_MONTHLY=price_xxx
VITE_STRIPE_PREMIUM_YEARLY=price_xxx
VITE_STRIPE_PRO_MONTHLY=price_xxx
VITE_STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/xxx

# ─── Stripe (serveur — webhook) ───────────────────────────────────
# Dashboard Stripe → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=sk_live_xxx

# Généré après avoir créé le webhook dans Stripe (étape suivante)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Même IDs que les VITE_ mais sans le préfixe (côté serveur)
STRIPE_PREMIUM_MONTHLY=price_xxx
STRIPE_PREMIUM_YEARLY=price_xxx
STRIPE_PRO_MONTHLY=price_xxx

# ─── Firebase Admin (serveur — webhook) ───────────────────────────
# Firebase Console → Paramètres → Comptes de service → Générer une clé privée
# Copie les valeurs du fichier JSON téléchargé
FIREBASE_PROJECT_ID=ton-projet-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@ton-projet.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"
