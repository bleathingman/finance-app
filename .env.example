# ─── Firebase ──────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Stripe ────────────────────────────────────────────────────────
# Clé publique (pk_live_... ou pk_test_... pour les tests)
VITE_STRIPE_PUBLIC_KEY=pk_test_XXXXXX

# IDs des prix créés dans ton dashboard Stripe
# Dashboard Stripe → Products → ton produit → Price ID
VITE_STRIPE_PREMIUM_MONTHLY=price_XXXXXX
VITE_STRIPE_PREMIUM_YEARLY=price_XXXXXX
VITE_STRIPE_PRO_MONTHLY=price_XXXXXX

# Lien vers le portail client Stripe
# Dashboard Stripe → Billing → Customer portal → Lien
VITE_STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/XXXXXX
